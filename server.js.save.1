// ------------------ DASHBOARD API ------------------
app.get('/api/dashboard', async (req, res) => {
    const selectedMonth = req.query.month || '';

    try {
        let query = `
        SELECT 
            c.name,
            c.phone,
            d.month,
            d.total_bottles,
            s.rate_per_bottle,
            s.maintenance_charges,
            (d.total_bottles * s.rate_per_bottle + s.maintenance_charges) AS total_bill,
            COALESCE(p.total_paid, 0) AS total_paid,
            (d.total_bottles * s.rate_per_bottle + s.maintenance_charges 
             - COALESCE(p.total_paid, 0)) AS balance
        FROM
        (
            SELECT 
                customer_id,
                DATE_FORMAT(date, '%b-%y') AS month,
                SUM(bottles_refilled) AS total_bottles
            FROM deliveries
            GROUP BY customer_id, month
        ) d
        JOIN customers c ON c.id = d.customer_id
        JOIN settings s ON s.month_year = d.month
        LEFT JOIN
        (
            SELECT 
                customer_id,
                DATE_FORMAT(date, '%b-%y') AS month,
                SUM(amount_paid) AS total_paid
            FROM payments
            GROUP BY customer_id, month
        ) p
        ON p.customer_id = d.customer_id AND p.month = d.month
        `;

        if (selectedMonth) {
            query += ` WHERE d.month = '${selectedMonth}'`;
        }

        const [rows] = await db.query(query);

        let summary = {
            totalCustomers: rows.length,
            totalRevenue: rows.reduce((sum, r) => sum + r.total_bill, 0),
            totalPending: rows.reduce((sum, r) => sum + r.balance, 0)
        };

        res.json({
            summary,
            data: rows
        });

    } catch (err) {
        res.status(500).json({ error: err.message });
    }
});


// ------------------ GET PAYMENTS ------------------
app.get('/api/payments', async (req, res) => {
    try {
        const [rows] = await db.query(`
            SELECT 
                p.id,
                c.name,
                p.amount_paid,
                p.date,
                p.method
            FROM payments p
            JOIN customers c ON c.id = p.customer_id
            ORDER BY p.date DESC
        `);

        res.json(rows);
    } catch (err) {
        res.status(500).json({ error: err.message });
    }
});


// ------------------ ADD PAYMENT ------------------
app.post('/api/payments', async (req, res) => {
    const { customer_id, amount_paid, method } = req.body;

    try {
        await db.query(`
            INSERT INTO payments (customer_id, amount_paid, method, date)
            VALUES (?, ?, ?, NOW())
        `, [customer_id, amount_paid, method]);

        res.json({ message: 'Payment added successfully' });

    } catch (err) {
        res.status(500).json({ error: err.message });
    }
});

